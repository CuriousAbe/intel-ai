# ============================================================
# Intel-AI 环境变量配置示例
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# ============================================================

# ── LLM 配置（必填）──────────────────────────────────────────
# API 密钥（支持 OpenAI / Claude / 任何 OpenAI 兼容接口）
LLM_API_KEY=your_api_key_here

# API 基础地址（默认 OpenAI，可替换为任何兼容服务）
# OpenAI:    https://api.openai.com/v1
# Claude:    https://api.anthropic.com/v1  （需 anthropic-to-openai 代理）
# 本地 LLM:  http://localhost:11434/v1     （Ollama）
LLM_API_BASE_URL=https://api.openai.com/v1

# 使用的模型名称（默认 gpt-5.3-codex）
LLM_MODEL=gpt-5.3-codex

# ── 搜索配置（可选，不填则使用 DuckDuckGo）───────────────────
# Google Custom Search API（更稳定，每天免费 100 次）
# 申请地址：https://developers.google.com/custom-search/v1/overview
# GOOGLE_SEARCH_API_KEY=your_google_api_key
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# 最多抓取的搜索结果数量（默认 8）
# MAX_SEARCH_RESULTS=8

# ── API 服务器配置（仅服务器模式使用）───────────────────────
# INTEL_AI__SERVER__HOST=0.0.0.0
# INTEL_AI__SERVER__PORT=8080
# INTEL_AI__DATABASE__URL=postgres://localhost/intel_ai
# INTEL_AI__QDRANT__URL=http://localhost:6334
